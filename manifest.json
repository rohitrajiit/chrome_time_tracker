{
  "manifest_version": 3,
  "name": "Daily Website Time Tracker",
  "description": "Tracks daily time spent on websites, with each day starting at 5:00 AM.",
  "version": "1.0.0",
  "permissions": [
    "alarms",
    "idle",
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Daily Website Time Tracker",
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}
